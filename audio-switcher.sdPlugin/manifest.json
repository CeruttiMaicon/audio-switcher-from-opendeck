{
	"$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
	"Name": "Audio Switcher (PipeWire)",
	"Version": "1.6.2",
	"Author": "maicon-dev",
	"UUID": "com.maicondev.opendeck.pipewire-sink-toggle",
	"Description": "PipeWire: toggle the default sink between two outputs, and show/adjust the default output volume (wpctl). Native Linux, no Wine.",
	"Icon": "imgs/icone",
	"Category": "Master Volume",
	"CategoryIcon": "imgs/icone",
	"CodePath": "bin/plugin.js",
	"OS": [
		{
			"Platform": "linux"
		}
	],
	"Nodejs": {
		"Version": "20"
	},
	"SDKVersion": 2,
	"Software": {
		"MinimumVersion": "6.4"
	},
	"Actions": [
		{
			"Name": "Toggle Audio Output",
			"UUID": "com.maicondev.opendeck.pipewire-sink-toggle.toggle",
			"Icon": "imgs/icone",
			"Tooltip": "Toggle the default PipeWire sink between two outputs configured in the property inspector.",
			"PropertyInspectorPath": "propertyInspector/index.html",
			"Controllers": ["Keypad"],
			"DisableAutomaticStates": true,
			"States": [
				{
					"Image": "imgs/icone"
				},
				{
					"Image": "imgs/icone-2"
				}
			]
		},
		{
			"Name": "Master Volume",
			"UUID": "com.maicondev.opendeck.pipewire-sink-toggle.master-volume",
			"Icon": "imgs/icone",
			"Tooltip": "Default PipeWire output volume. Circular meter; configurable step per detent. Refreshes when the default sink changes.",
			"PropertyInspectorPath": "propertyInspector/master-volume.html",
			"Controllers": ["Keypad", "Encoder"],
			"DisableCaching": true,
			"UserTitleEnabled": false,
			"Encoder": {
				"layout": "layouts/master-volume-encoder.json",
				"Icon": "imgs/mv-key-blank",
				"TriggerDescription": {
					"Rotate": "Adjust volume",
					"Push": "Toggle mute",
					"Touch": "Default output volume"
				}
			},
			"States": [
				{
					"Image": "imgs/mv-key-blank",
					"ShowTitle": true,
					"Title": "",
					"TitleAlignment": "middle",
					"TitleColor": "#f8fafc",
					"FontSize": 22,
					"FontStyle": "Bold"
				}
			]
		}
	]
}
